# ScreenMind Configuration
# Copy this to .env and adjust as needed

# Capture Settings
CAPTURE_INTERVAL=30
SCREENSHOT_QUALITY=70
DATA_DIR=~/.screenmind

# Model Settings
GEMMA_MODE=local
# GEMMA_MODE=api  # WARNING: sends screenshots to Google AI Studio — disables local-only guarantee
# GOOGLE_API_KEY=your-key-here

# llama-server (local inference)
# NOTE: Do NOT set port in both LLAMA_SERVER_HOST and LLAMA_SERVER_PORT — they will silently diverge.
# LLAMA_SERVER_HOST=http://127.0.0.1:5809
# LLAMA_SERVER_PORT=5809

# Developer Context
WORKSPACE_DIRS=~/Projects,~/Desktop

# Privacy
BLOCKED_APPS=

# Hotkey
BOOKMARK_HOTKEY=ctrl+shift+b
